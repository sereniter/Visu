{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visu/schemas/flow_schema_v1.json",
  "title": "VISU Flow Definition v1",
  "description": "Deterministic UI flow with strict action types",
  "type": "object",
  "additionalProperties": false,
  "required": ["flow_id", "version", "steps"],
  "properties": {
    "flow_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "step_id"],
      "properties": {
        "step_id": { "type": "string", "minLength": 1 },
        "action": {
          "type": "string",
          "enum": ["navigate", "click", "fill", "wait", "screenshot", "done"]
        },
        "url": { "type": "string" },
        "selector": { "type": "string" },
        "value": { "type": "string" },
        "timeout_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
