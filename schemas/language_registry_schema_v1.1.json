{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visu/schemas/language_registry_schema_v1.1.json",
  "title": "VISU Language Registry v1.1",
  "description": "Governance for supported TTS languages with male/female voice selection per language.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "supported"],
  "properties": {
    "version": { "type": "string", "const": "1.1" },
    "supported": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "adapter", "sampleRate", "nativeModelRate", "voices"],
        "properties": {
          "name": { "type": "string" },
          "adapter": { "type": "string", "enum": ["local_piper"] },
          "sampleRate": { "type": "integer", "const": 48000 },
          "nativeModelRate": { "type": "integer" },
          "voices": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["voice", "modelPath", "modelConfig", "modelHash"],
              "properties": {
                "voice": { "type": "string" },
                "modelPath": { "type": "string" },
                "modelConfig": { "type": "string" },
                "modelHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          }
        }
      }
    }
  }
}
