{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visu/schemas/scene_schema_v1.4.json",
  "title": "VISU Mode C Contract v1.4",
  "description": "Structured scene contract for Mode C with topic, language, governed visual assets or remotion scenes, script templates, narration.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "video_id", "topic", "language", "scenes"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.4" },
    "video_id": { "type": "string" },
    "topic": { "type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$" },
    "language": { "type": "string", "minLength": 1 },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["scene_id", "duration_sec", "visual", "narration"],
            "properties": {
              "scene_id": { "type": "string" },
              "duration_sec": { "type": "number", "exclusiveMinimum": 0 },
              "visual": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "asset_path", "prompt_key", "seed", "model_version"],
                "properties": {
                  "type": { "type": "string", "const": "governed_image" },
                  "asset_path": { "type": "string" },
                  "prompt_key": { "type": "string" },
                  "seed": { "type": "integer" },
                  "model_version": { "type": "string" },
                  "visual_style": {
                    "type": "string",
                    "enum": [
                      "war_documentary",
                      "historical_archive",
                      "geopolitical_tension",
                      "news_report",
                      "impact_moment"
                    ]
                  },
                  "motion": {
                    "type": "object",
                    "required": ["type"],
                    "additionalProperties": false,
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "zoom_in",
                          "zoom_out",
                          "pan_left",
                          "pan_right",
                          "pan_diagonal_tl",
                          "pan_diagonal_br"
                        ]
                      },
                      "focus": {
                        "type": "string",
                        "enum": ["center", "left", "right", "top", "bottom"]
                      },
                      "intensity": {
                        "type": "number",
                        "minimum": 0.01,
                        "maximum": 0.5
                      },
                      "easing": {
                        "type": "string",
                        "enum": ["linear", "ease_in", "ease_out", "ease_in_out", "spring", "bounce"]
                      },
                      "motion_blur": {
                        "type": "boolean"
                      }
                    }
                  },
                  "grade": {
                    "type": "string",
                    "enum": [
                      "cinematic_dark",
                      "warm_sunset",
                      "cold_war",
                      "news_neutral",
                      "high_contrast"
                    ]
                  },
                  "grain": { "type": "boolean" },
                  "parallax": {
                    "type": "object",
                    "required": ["foreground_path", "depth"],
                    "additionalProperties": false,
                    "properties": {
                      "foreground_path": { "type": "string" },
                      "depth": { "type": "number", "minimum": 0, "maximum": 1 }
                    }
                  }
                }
              },
              "narration": {
                "type": "object",
                "additionalProperties": false,
                "required": ["text_template_key", "language", "voice_gender", "speed"],
                "properties": {
                  "text_template_key": { "type": "string" },
                  "language": { "type": "string" },
                  "voice_gender": { "type": "string", "enum": ["male", "female"] },
                  "speed": { "type": "number" }
                }
              },
              "transition": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["fade", "slide", "wipe", "flip", "clockWipe", "iris", "light_leak", "none"]
                  },
                  "duration_sec": { "type": "number", "minimum": 0.1, "maximum": 2.0 },
                  "timing": { "type": "string", "enum": ["spring", "linear"] },
                  "direction": { "type": "string", "enum": ["from-left", "from-right", "from-top", "from-bottom"] }
                }
              },
              "audio": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "ambient_path": { "type": "string" },
                  "ambient_volume": { "type": "number", "minimum": 0, "maximum": 1 },
                  "sfx": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["path", "start_sec"],
                      "additionalProperties": false,
                      "properties": {
                        "path": { "type": "string" },
                        "start_sec": { "type": "number", "minimum": 0 },
                        "volume": { "type": "number", "minimum": 0, "maximum": 1 }
                      }
                    }
                  }
                }
              },
              "overlays": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "start_sec", "duration_sec"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "lower_third",
                        "stat_badge",
                        "source_tag",
                        "highlight_circle",
                        "arrow_pointer",
                        "shape"
                      ]
                    },
                    "text": { "type": "string", "minLength": 1, "maxLength": 60 },
                    "subtext": { "type": "string", "maxLength": 80 },
                    "label": { "type": "string", "maxLength": 60 },
                    "position": {
                      "type": "string",
                      "enum": ["bottom_left", "bottom_right", "top_left", "top_right"]
                    },
                    "x": { "type": "integer", "minimum": 0, "maximum": 1919 },
                    "y": { "type": "integer", "minimum": 0, "maximum": 1079 },
                    "x1": { "type": "integer", "minimum": 0, "maximum": 1919 },
                    "y1": { "type": "integer", "minimum": 0, "maximum": 1079 },
                    "x2": { "type": "integer", "minimum": 0, "maximum": 1919 },
                    "y2": { "type": "integer", "minimum": 0, "maximum": 1079 },
                    "radius": { "type": "integer", "minimum": 20, "maximum": 400 },
                    "color": { "type": "string", "pattern": "^[0-9a-fA-F]{6}$" },
                    "pulse": { "type": "boolean" },
                    "pulse_speed": {
                      "type": "number",
                      "minimum": 0.5,
                      "maximum": 5.0
                    },
                    "animation": {
                      "type": "string",
                      "enum": ["slide_up", "fade"]
                    },
                    "count_up": { "type": "boolean" },
                    "glow": { "type": "boolean" },
                    "glow_radius": { "type": "integer", "minimum": 1, "maximum": 100 },
                    "shape": {
                      "type": "string",
                      "enum": ["triangle", "star", "circle", "pie"]
                    },
                    "size": { "type": "integer", "minimum": 10, "maximum": 500 },
                    "fill": { "type": "boolean" },
                    "draw_on": { "type": "boolean" },
                    "language": { "type": "string" },
                    "start_sec": { "type": "number", "minimum": 0 },
                    "duration_sec": { "type": "number", "minimum": 0.5 },
                    "fade_in_sec": { "type": "number", "minimum": 0 },
                    "fade_out_sec": { "type": "number", "minimum": 0 }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["scene_id", "visual", "narration"],
            "properties": {
              "scene_id": { "type": "string" },
              "visual": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "component", "props"],
                "properties": {
                  "type": { "type": "string", "const": "remotion" },
                  "component": { "type": "string", "enum": ["SceneTitleCard"] },
                  "props": { "type": "object" }
                }
              },
              "narration": {
                "type": "object",
                "additionalProperties": false,
                "required": ["text_template_key", "language", "voice_gender", "speed"],
                "properties": {
                  "text_template_key": { "type": "string" },
                  "language": { "type": "string" },
                  "voice_gender": { "type": "string", "enum": ["male", "female"] },
                  "speed": { "type": "number" }
                }
              }
            }
          }
        ]
      }
    }
  }
}
