{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visu/schemas/scene_schema_v1.json",
  "title": "VISU Mode C Contract v1",
  "description": "Structured scene contract for Mode C minimal execution. Pre-baked assets only; no TTS.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "video_id", "scenes"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "video_id": { "type": "string" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scene_id", "video_path", "narration_path", "duration_sec"],
        "properties": {
          "scene_id": { "type": "string" },
          "video_path": { "type": "string" },
          "narration_path": { "type": "string" },
          "duration_sec": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
