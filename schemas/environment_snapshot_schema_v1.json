{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visu/schemas/environment_snapshot_schema_v1.json",
  "title": "VISU Environment Snapshot v1",
  "description": "Captured environment and binary fingerprints for determinism verification (Sprint 7).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ffmpegVersionFull",
    "ffmpegBuildConf",
    "ffmpegBinaryFingerprint",
    "nodeVersion",
    "piperBinaryFingerprint",
    "piperModelHash",
    "configHash",
    "capturedAt"
  ],
  "properties": {
    "ffmpegVersionFull": { "type": "string" },
    "ffmpegBuildConf": { "type": "string" },
    "ffmpegBinaryFingerprint": { "type": "string" },
    "nodeVersion": { "type": "string" },
    "piperVersion": { "type": ["string", "null"] },
    "piperBinaryFingerprint": { "type": "string" },
    "piperModelHash": { "type": "string" },
    "configHash": { "type": "string" },
    "capturedAt": { "type": "string" }
  }
}
