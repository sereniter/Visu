{
  "contentRoot": "/Users/play/Documents/recipes",
  "outputRoot": "/Users/play/Documents/menu_item",
  "rendering": {
    "renderer": "remotion"
  },
  "execution": {
    "actionTimeoutMs": 30000,
    "videoDir": "videos",
    "artifactsDir": "artifacts",
    "viewport": {
      "width": 1920,
      "height": 1080
    }
  },
  "browser": {
    "headless": true,
    "locale": "en-US"
  },
  "screenCapture": {
    "videoDevice": "0",
    "audioDevice": "0",
    "startupWaitMs": 500
  },
  "tts": {
    "provider": "local_piper",
    "defaultVoice": "te",
    "speechRate": 0.95,
    "sampleRate": 48000,
    "outputFormat": "wav",
    "modelPath": "models/piper/te_IN-venkatesh-medium.onnx",
    "modelConfigPath": "models/piper/te_IN-venkatesh-medium.onnx.json",
    "piperPath": "/usr/local/opt/piper/piper"
  },
  "encoding": {
    "encoding_profile_version": "v1",
    "video_codec": "libx264",
    "pix_fmt": "yuv420p",
    "profile": "high",
    "preset": "medium",
    "crf": 18,
    "audio_codec": "aac",
    "audio_sample_rate": 48000
  },
  "remotion": {
    "templatesRoot": "./remotion-templates",
    "accentColor": "#FF6B35",
    "enabled": true
  }
}
