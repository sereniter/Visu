{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@engines/*": ["src/engines/*"],
      "@adapters/*": ["src/adapters/*"],
      "@validators/*": ["src/validators/*"]
    },
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "exclude": ["remotion-templates"]
}
